// Set field required based on another field value

// Trigger field  | Name: Field1 | DC id: customfield_21803 | Cloud id: customfield_10168
// Affected field | Name: Field2 | DC id: customfield_21804 | Cloud id: customfield_10296

try {
    const triggerField = getFieldById("customfield_10168"); //Field1
    const affectedField = getFieldById("customfield_10296"); //Field2
    const triggerValue = triggerField.getValue();
    if (triggerValue && triggerValue.value === "Yes") {
        affectedField.setVisible(true);
        affectedField.setRequired(true);
    } else {
        affectedField.setVisible(false);
        affectedField.setRequired(false);
    }
} catch (error) {
    console.error("Behavior execution failed:", error);
}

