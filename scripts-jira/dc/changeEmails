import logging
import requests
import json
import csv

user = "gmuller"
pw = "here"
header = {"Content-type": "application/json"}

logging.basicConfig(filename="email-change-logs.log",
					format='%(asctime)s %(message)s',
					filemode='w')
logger=logging.getLogger()

#Now we are going to Set the threshold of logger to DEBUG
logger.setLevel(logging.INFO)

def activate_user(username, email):
	payload_data = {
		"name": username,
		"emailAddress": email,
		"active": True
	}
	data = json.dumps(payload_data)
	return data

def update_email(username, email):
	payload_data = {
		"name": username,
		"emailAddress": email,
		}
	payload = json.dumps(payload_data)
	req = requests.put("https://jira-qa2.com/rest/api/2/user?username={}".format(username), headers=header, auth=(user,pw), data=payload, verify=False)
	if req.ok:
		logger.info("SUCCESS updated user,{},{}".format(username, email))
	else:
		logger.error("FAILED,{},{},{}".format(username, req.text, req.status_code))
		if "lead" in req.text:
			logger.info("ACTIVATING USER,{}".format(username))
			act_payload = activate_user(username, email)
			act_req = requests.put("https://jira-qa2.com/rest/api/2/user?username={}".format(username), headers=header, auth=(user,pw), data=act_payload, verify=False)
			if act_req.ok:
				logger.info("SUCCESS update/activate user,{},{}".format(username, email))
			else:
				logger.error("FAILED update/activate user ,{},{},{}".format(username, req.text, req.status_code))

def main(csv_file):
    with open(csv_file) as csvfile:
        line = csv.reader(csvfile, delimiter=',')
        for row in line:
            email_address = row[1]
            user_name = row[0]
            new_email = email_address.split("@")[0] + "+dummy@" + email_address.split("@")[1]
            update_email(user_name, new_email)

main("remaining-users.csv")
