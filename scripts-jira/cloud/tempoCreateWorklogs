def create_worklog_payload(description, timestamp, timespent, issuekey, author):
    payload = {
        "description": description,
        "issueKey": issuekey,
        "authorAccountId": author,
        "timeSpentSeconds": timespent,
        "startDate": timestamp
    }
    data = json.dumps(payload)
    return data

def main(csv_file):
    with open(csv_file) as csvfile:
        line = csv.reader(csvfile, delimiter=',')
        for row in line:
            worklog_id = row[0]
            issuekey = row[2]
            all_worklog = row[4]
            worklog_description = all_worklog.split(';')[0]
            worklog_time = all_worklog.split(';')[1].split('T')[0]
            worklog_author = all_worklog.split(';')[2]
            worklog_timespent = all_worklog.split(';')[3]
            payload = create_worklog_payload(worklog_description, worklog_time, worklog_timespent, issuekey, worklog_author)
            req = requests.post('<https://api.tempo.io/4/worklogs>', headers=headers, data=payload)
            if req.ok:
                logger.info("SUCCESS - Added worklog {} to issue: {}: new_worklog_id = {}".format(worklog_id, issuekey, req.json()["tempoWorklogId"]))
            else:
                logger.error("FAILED - Fail to add worklog {} to issue: {} - {} - {}".format(worklog_id, issuekey, req.text, req.status_code))

main('worklogs_april2.csv')
