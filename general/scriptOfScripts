-- script by Chico
-- This script can be updated to do things in bulk. "cookie" get from inspecting the page while doing the action once in the UI, and "url" can replace with anything

cookie='<my_cookie>'
cat users.csv | while read line;
do
	echo "Deactivating user $line"
	curl -X POST --header "$cookie" --url "https://admin.atlassian.com/gateway/api/adminhub/um/site/731a8c72-f1687b471dc9d755/users/$line/deactivate" -i
done
